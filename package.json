{
  "name": "le-journal",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && npm run typecheck",
    "lint:staged": "eslint $(git diff --cached --name-only --diff-filter=ACM \"*.ts\" \"*.tsx\" | sed 's| |\\\\ |g')",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "prettier:staged": "prettier --write",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "circular": "madge --circular --extensions ts,tsx --ts-config tsconfig.json ."
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "firebase": "^12.16.0",
    "js-cookie": "^3.0.5",
    "mongodb": "^7.5.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-audio-player": "^0.17.0",
    "react-dom": "^19.2.7",
    "ua-parser-js": "^1.0.41"
  },
  "devDependencies": {
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ua-parser-js": "^0.7.39",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "knip": "^6.27.0",
    "madge": "^8.0.0",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "postcss": "^8.5.20"
  },
  "allowScripts": {
    "@firebase/util@1.15.1": true,
    "@parcel/watcher@2.5.6": true,
    "protobufjs@7.6.5": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
